{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "openrouter": {
      "options": {
        "apiKey": "TU_API_KEY_AQUI"
      }
    }
  },
  "lsp": {
    "python": {
      "command": ["npx", "pyright", "--stdio"],
      "extensions": ["py"]
    },
    "typescript": {
      "command": ["npx", "typescript-language-server", "--stdio"],
      "extensions": ["ts", "tsx", "js", "jsx", "mjs", "cjs"]
    }
  }
}
